# Email Service — Go Environment Variables

# ── SMTP (AWS SES) ────────────────────────────────────────────────────────────
SMTP_HOSTNAME=email-smtp.us-east-1.amazonaws.com
SMTP_USERNAME=<your-ses-access-key>
SMTP_PASSWORD=<your-ses-secret-key>

# ── SMTP port: 587 (STARTTLS, default) or 465 (SMTPS) ────────────────────────
SMTP_PORT=587

# ── HTTP server port (default: 9090) ─────────────────────────────────────────
PORT=9090

# ── HTTP Server Timeouts (Go duration format, e.g. 5s, 1m) ───────────────────
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s
